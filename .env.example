# Copy this file to .env and fill in your values.
# docker compose will automatically load .env

# === Required ===
# Standard user key: read access to IOCs, jobs, results, OpenCTI read endpoints,
# and log analysis. Used by your frontend and analyst tooling.
APP_API_KEY=change-me-to-a-strong-random-secret

# Admin key: full access including triggering fetches, exporting STIX, and
# pushing to OpenCTI. Keep this out of the frontend; use server-side only.
# If not set, APP_API_KEY is used for admin routes too (single-key mode).
ADMIN_API_KEY=change-me-to-a-different-strong-secret

# === Optional: external API keys ===
OTX_API_KEY=
VIRUSTOTAL_API_KEY=

# === Optional: OpenCTI integration ===
OPENCTI_ENABLED=false
OPENCTI_URL=http://localhost:8080
OPENCTI_API_KEY=

# === Optional: CORS (comma-separated origins, or * for all) ===
# Set to your frontend domain(s) in production, e.g.:
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# === Optional: tuning ===
RATE_LIMIT_PER_MINUTE=120
ENABLE_SCHEDULER=true
LOG_DB_PATH=log_api.db
