# Copy this file to .env and fill in your values.
# docker compose will automatically load .env

# === Required ===
# Standard user key: read access to IOCs, jobs, results, OpenCTI read endpoints,
# and log analysis. Used by your frontend and analyst tooling.
APP_API_KEY=change-me-to-a-strong-random-secret

# Admin key: full access including triggering fetches, exporting STIX, and
# pushing to OpenCTI. Keep this out of the frontend; use server-side only.
# If not set, APP_API_KEY is used for admin routes too (single-key mode).
ADMIN_API_KEY=change-me-to-a-different-strong-secret

# === Optional: external API keys (all free) ===
# These make the OSINT engine richer. With NONE set, the engine still returns
# real data from abuse.ch's keyless Feodo blocklist and RSS feeds, and the
# dashboard's NVD CVE connector works keyless too.
OTX_API_KEY=
VIRUSTOTAL_API_KEY=
# abuse.ch now requires a free Auth-Key for URLHaus (get one at auth.abuse.ch).
# Without it, the engine still pulls the keyless Feodo IP blocklist.
ABUSECH_AUTH_KEY=

# === Optional: OpenCTI integration ===
OPENCTI_ENABLED=false
OPENCTI_URL=http://localhost:8080
OPENCTI_API_KEY=

# === Optional: CORS (comma-separated origins, or * for all) ===
# Set to your frontend domain(s) in production, e.g.:
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# === Optional: tuning ===
RATE_LIMIT_PER_MINUTE=120
ENABLE_SCHEDULER=true
LOG_DB_PATH=log_api.db

# === Dashboard API (:8002) ===
# Production hardening gate. When true (or DASHBOARD_ENV=production) the API
# refuses to start with any insecure default secret - use it in real deploys.
DASHBOARD_REQUIRE_SECRETS=false

# JWT signing secret. Set a long random value in production (`openssl rand -hex
# 32`). If left unset the API generates a per-install random secret and persists
# it next to the database (never the old shared default), so local runs are
# secure-by-default; DASHBOARD_REQUIRE_SECRETS makes an explicit value mandatory.
DASHBOARD_JWT_SECRET=change-me-to-a-long-random-value

# Encryption-at-rest key for stored secrets (connector/integration credentials).
# Generate once and keep it STABLE and backed up separately from the DB:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Unset falls back to the JWT secret (fine for local; set it explicitly in prod).
# DASHBOARD_ENCRYPTION_KEY=

# Bootstrap admin (created on first run when the users table is empty). The
# password must be changed on first login. Set a strong value in production -
# DASHBOARD_REQUIRE_SECRETS refuses to start if it is still the demo default.
DASHBOARD_ADMIN_EMAIL=admin@threatorbit.space
DASHBOARD_ADMIN_PASSWORD=ChangeMe123!

# Comma-separated origins allowed to call the dashboard API from a browser.
# Must be explicit origins - '*' is refused because credentials are enabled.
DASHBOARD_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SSRF guard: outbound user URLs (webhooks, custom connectors, Slack routing)
# may not target the local host or private/reserved ranges. Set true only for
# local development that needs to point a webhook at an internal/loopback URL.
DASHBOARD_ALLOW_PRIVATE_URLS=false

# Billing (Stripe self-serve) - entirely optional. With no STRIPE_SECRET_KEY the
# billing endpoints degrade to "not configured" and license keys are the only
# path. When set, a completed Checkout mints the plan's signed license key.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...      # maps to the Starter plan
# STRIPE_PRICE_PRO=price_...          # maps to the Pro/Professional plan
# DASHBOARD_BILLING_RETURN_URL=https://app.yourdomain.com/dashboard/config

# SSO (OIDC) - optional single sign-on (Entra ID, Okta, Google, Auth0, Keycloak…).
# With no OIDC_ISSUER, email+password is the only path. Register OIDC_REDIRECT_URI
# (the backend callback) with your IdP. Users are JIT-provisioned on first login;
# OIDC_ROLE_MAP maps an IdP group to a role (admin|manager|analyst|viewer).
# OIDC_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
# OIDC_CLIENT_ID=...
# OIDC_CLIENT_SECRET=...
# OIDC_REDIRECT_URI=https://api.yourdomain.com/auth/sso/callback
# OIDC_POST_LOGIN_URL=https://app.yourdomain.com/login
# OIDC_SCOPES=openid email profile
# OIDC_GROUPS_CLAIM=groups
# OIDC_ROLE_MAP={"soc-admins":"admin","soc-analysts":"analyst"}
# OIDC_DEFAULT_ROLE=viewer
# OIDC_ALLOWED_DOMAINS=yourcompany.com

# Data mode: "demo" seeds realistic showcase data; "live" starts empty and
# ingests REAL threat intelligence via connectors (Feeds -> Sources).
DASHBOARD_DATA_MODE=demo

# Synthetic-telemetry switch (live mode). "on" keeps the console alive with
# representative generated telemetry before any log forwarding exists.
# "off" = REAL DATA ONLY: no synthetic events ever; the engine boots paused.
# The go-live runbook (docs/GOING_LIVE.md) sets live + off together.
DASHBOARD_ENGINE=on

# Self-service signup (/auth/register). Set false for closed deployments.
DASHBOARD_ALLOW_REGISTRATION=true

# Opt-in PII/secret redaction of raw log text at ingest, BEFORE persistence.
# Comma-separated categories: email, secret, cc, ssn. Empty = store verbatim.
# Lossy and irreversible by design — see docs/PII_HANDLING.md.
# DASHBOARD_LOG_REDACT=email,secret

# Max HTTP request body accepted (bytes) — DoS guard, rejected with 413 at the
# edge before the body is buffered. 25 MB default fits a 5000-line log batch.
# Raise if you post larger batches; 0 disables the cap.
# DASHBOARD_MAX_BODY_BYTES=26214400

# Failed-login throttling: attempts allowed per client+email inside the window.
DASHBOARD_AUTH_MAX_FAILURES=10
DASHBOARD_AUTH_FAILURE_WINDOW_SEC=300

# Service bridge: where the dashboard finds the other two services and the
# X-API-Key it presents to them. Inside docker compose these are set
# automatically; for local (non-docker) runs the localhost defaults work.
#THREAT_API_URL=http://127.0.0.1:8000
#LOG_API_URL=http://127.0.0.1:8001
#SERVICES_API_KEY=<defaults to APP_API_KEY>
#SERVICES_ADMIN_KEY=<defaults to ADMIN_API_KEY>

# === Data lifecycle: retention cold-storage ===
# Retention enforcement archives each purged batch to compressed NDJSON BEFORE
# deleting it (a purge is aborted if archival fails). Two independent sinks:
#   1) a local directory (sync it to object storage yourself), and/or
#   2) direct object storage (S3 / S3-compatible) via a SigV4-signed PUT.
# Unset both = purge-only (the default).
#DASHBOARD_ARCHIVE_DIR=/data/archive
#DASHBOARD_ARCHIVE_S3_BUCKET=my-cold-logs
#DASHBOARD_ARCHIVE_S3_PREFIX=threatorbit/retention
#DASHBOARD_ARCHIVE_S3_REGION=us-east-1
# Set _ENDPOINT for an S3-compatible store (MinIO/R2/B2) → path-style; unset for AWS.
#DASHBOARD_ARCHIVE_S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
# Credentials come from the standard AWS environment:
#AWS_ACCESS_KEY_ID=...
#AWS_SECRET_ACCESS_KEY=...
#AWS_SESSION_TOKEN=...

# === Agentless log pull (S3 / S3-compatible) ===
# Tail a bucket prefix on an interval and ingest new objects (logs already
# landing in object storage flow into the SIEM with no agent). Off unless a
# bucket is set; uses the same AWS credentials above. _ORG stamps the events for
# per-tenant pull; _ENDPOINT targets an S3-compatible store.
#DASHBOARD_S3_PULL_BUCKET=my-log-bucket
#DASHBOARD_S3_PULL_PREFIX=cloudtrail/
#DASHBOARD_S3_PULL_REGION=us-east-1
#DASHBOARD_S3_PULL_ENDPOINT=
#DASHBOARD_S3_PULL_ORG=org-default
#DASHBOARD_S3_PULL_SECONDS=60

# === Frontend ===
# Point the Next.js app at a non-default dashboard API URL.
#NEXT_PUBLIC_API_URL=http://localhost:8002
