# ThreatOrbit collector configuration (copy to /etc/threatorbit/collector.env).
# A write-scoped API key minted under Settings → API (starts with to_sk_live_).

THREATORBIT_URL=https://soc.example.com:8002
THREATORBIT_API_KEY=to_sk_live_replace_me
THREATORBIT_PATHS=/var/log/auth.log,/var/log/syslog,/var/log/nginx/*.log
THREATORBIT_FORMAT=auto
# THREATORBIT_SOURCE defaults to the hostname
THREATORBIT_BATCH=500
THREATORBIT_INTERVAL=5
THREATORBIT_STATE=/var/lib/threatorbit/collector.state

# TLS / mTLS enrolment (recommended in production):
# THREATORBIT_CA=/etc/ssl/certs/threatorbit-ca.pem
# THREATORBIT_CLIENT_CERT=/etc/threatorbit/collector.crt
# THREATORBIT_CLIENT_KEY=/etc/threatorbit/collector.key
